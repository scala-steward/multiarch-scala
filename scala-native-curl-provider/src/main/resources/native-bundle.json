{
  "name": "scala-native-curl",
  "libraries": [
    {
      "name": "curl",
      "fullPath": true,
      "platforms": {
        "linux-x86_64":    { "flags": ["-lpthread", "-ldl"] },
        "linux-aarch64":   { "flags": ["-lpthread", "-ldl"] },
        "macos-x86_64":    { "flags": ["-framework", "Security", "-framework", "SystemConfiguration"] },
        "macos-aarch64":   { "flags": ["-framework", "Security", "-framework", "SystemConfiguration"] },
        "windows-x86_64":  { "flags": ["-lws2_32", "-lcrypt32", "-lbcrypt", "-ladvapi32", "-lncrypt", "-lntdll", "-lmsvcrt"] },
        "windows-aarch64": { "flags": ["-lws2_32", "-lcrypt32", "-lbcrypt", "-ladvapi32", "-lncrypt", "-lntdll", "-lmsvcrt"] }
      }
    },
    {
      "name": "curl_static",
      "fullPath": true,
      "platforms": {
        "windows-x86_64":  { "flags": [] },
        "windows-aarch64": { "flags": [] }
      }
    },
    {
      "name": "idn2",
      "fullPath": true,
      "platforms": {
        "linux-x86_64":    { "flags": [] },
        "linux-aarch64":   { "flags": [] },
        "macos-x86_64":    { "flags": [] },
        "macos-aarch64":   { "flags": [] },
        "windows-x86_64":  { "flags": [] },
        "windows-aarch64": { "flags": [] }
      }
    }
  ],
  "globalFlags": []
}
